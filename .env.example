POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=social
DATABASE_URL=postgresql://app:app@postgres:5432/social
GO_DATABASE_URL=postgres://app:app@postgres:5432/social?sslmode=disable
REDIS_ADDR=redis:6379
KAFKA_BROKERS=kafka:9092
POST_CREATED_TOPIC=post.created.v1
ADMIN_TOKEN=dev-admin-token
PROMETHEUS_URL=http://prometheus:9090
RUNTIME_MODE=docker
KUBERNETES_NAMESPACE=social-feed
HEALING_POLL_INTERVAL_SECONDS=10
HEALING_CONFIDENCE_THRESHOLD=0.75
HEALING_COOLDOWN_SECONDS=120

